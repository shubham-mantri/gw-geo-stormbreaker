# gw-geo-stormbreaker — example environment configuration.
# Copy to `.env` and fill in real values. All settings are prefixed `GEO_` (see
# `src/gw_geo/common/config.py`). Only the LLM / embedding gateway settings are documented here;
# other settings (DB, S3, engine keys, JWT, etc.) use the defaults in `config.py` unless overridden.

# --- LLM + embedding gateway ---------------------------------------------------------------------
# How the content engine reaches LLMs + embedding models:
#   "portkey" (default) — route every chat/embedding call through the Portkey gateway. Provider
#                         routing and virtual keys live in the Portkey dashboard Config below, not
#                         in this file. Requires GEO_PORTKEY_API_KEY.
#   "direct"            — call Anthropic / OpenAI directly using GEO_ANTHROPIC_API_KEY /
#                         GEO_OPENAI_API_KEY.
# If "portkey" is selected but GEO_PORTKEY_API_KEY is empty, the engine falls back to the direct
# clients gracefully.
GEO_LLM_GATEWAY=portkey

# Portkey gateway credentials + routing config.
GEO_PORTKEY_API_KEY=
GEO_PORTKEY_BASE_URL=https://api.portkey.ai/v1
GEO_PORTKEY_CONFIG=pc-portke-0dd3de

# --- Direct-provider keys (used when GEO_LLM_GATEWAY=direct, or as the Portkey fallback) ----------
GEO_ANTHROPIC_API_KEY=
GEO_OPENAI_API_KEY=

# Embedding model slug (native slug; passed through to Portkey or OpenAI unchanged).
GEO_EMBEDDING_MODEL=text-embedding-3-large
