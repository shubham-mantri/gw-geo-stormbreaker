  "additional_info": {
    "business_profile": {
      "inventory_nature": "100% Engineered Whole Unit Systems - Custom-designed jet aerators, jet mixers, and complete turnkey wastewater treatment systems with supporting pumps and blowers. No off-the-shelf replacement parts or consumables catalog.",
      "business_identity": "B2B manufacturer of submerged jet aeration and jet mixing systems for industrial wastewater treatment, serving chemical, pharmaceutical, food processing, pulp & paper, and municipal sectors with engineered-to-order equipment rather than catalog parts.",
      "primary_verticals": [
        "Jet Aeration Systems",
        "Jet Mixing Systems",
        "Hydraulic Sludge Mixers",
        "Sequencing Batch Reactors (SBR)",
        "Supporting Equipment (Pumps, Blowers, Backflush Systems)"
      ],
      "explicit_out_of_scope": [
        "Replacement parts distribution",
        "Consumables (chemicals, filters, membranes)",
        "Surface aerators or mechanical mixers",
        "Residential wastewater equipment",
        "Rental or leasing services",
        "Used or refurbished equipment",
        "Installation-only services without equipment supply",
        "Non-wastewater mixing applications (food processing mixers, pharmaceutical reactors as standalone products)",
        "Diffused air systems (fine bubble diffusers, membrane diffusers)",
        "Biological treatment media or additives"
      ]
    }
  },
